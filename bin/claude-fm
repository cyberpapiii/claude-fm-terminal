#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.0"
DEFAULT_STREAM="https://www.youtube.com/watch?v=tRsQsTMvPNg"
YTDLP_FORMAT="${CLAUDE_FM_FORMAT:-93/best[height<=360]}"
PIDFILE="${CLAUDE_FM_PIDFILE:-${TMPDIR:-/tmp}/claude-fm-${UID:-0}.pid}"

TMPDIR_RUNTIME=""
AUDIO_PID=""
FFMPEG_PID=""

usage() {
  cat <<'EOF'
claude-fm - play Claude FM in your terminal

Usage:
  claude-fm                 Play Claude FM as centered ASCII art
  claude-fm <url>           Play a YouTube livestream or video
  claude-fm --color         Colored terminal character art
  claude-fm --audio         Audio only
  claude-fm --stable        Lower FPS ASCII mode
  claude-fm stop            Kill stuck claude-fm sessions
  claude-fm doctor          Check dependencies
  claude-fm setup           Print dependency install command
  claude-fm --help          Show this help
  claude-fm --version       Show version

Controls:
  q or ESC     quit
  Ctrl-C       quit
EOF
}

have() {
  command -v "$1" >/dev/null 2>&1
}

setup_command() {
  case "$(uname -s)" in
    Darwin)
      echo "brew install yt-dlp mpv ffmpeg chafa"
      ;;
    Linux)
      if have apt-get; then
        echo "sudo apt-get update && sudo apt-get install -y yt-dlp mpv ffmpeg chafa"
      elif have dnf; then
        echo "sudo dnf install -y yt-dlp mpv ffmpeg chafa"
      elif have pacman; then
        echo "sudo pacman -S --needed yt-dlp mpv ffmpeg chafa"
      else
        echo "# Install yt-dlp, mpv, ffmpeg, and chafa with your package manager"
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      echo "winget install yt-dlp.yt-dlp mpv.net Gyan.FFmpeg"
      echo "# Install chafa manually or use WSL for ASCII mode"
      ;;
    *)
      echo "# Install yt-dlp, mpv, ffmpeg, and chafa for your platform"
      ;;
  esac
}

doctor() {
  local ok=1
  echo "claude-fm doctor"
  echo

  for dep in yt-dlp mpv ffmpeg chafa; do
    if have "$dep"; then
      echo "  $dep  ok  ($(command -v "$dep"))"
    else
      echo "  $dep  missing"
      ok=0
    fi
  done

  echo
  if [[ "$ok" -eq 1 ]]; then
    echo "Ready. Run: claude-fm"
    return 0
  fi

  echo "Install dependencies:"
  setup_command
  return 1
}

record_pid() {
  echo "$1" >>"$PIDFILE"
}

kill_matching() {
  local pattern="$1"
  local signal="${2:-TERM}"
  local pid count=0

  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    if kill "-$signal" "$pid" 2>/dev/null; then
      count=$((count + 1))
    fi
  done < <(pgrep -f "$pattern" 2>/dev/null || true)

  echo "$count"
}

restore_terminal() {
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l'
  printf '\033[?25h\033[0m\033[?1049l'
  stty sane 2>/dev/null || true
}

cleanup() {
  local pid

  for pid in "$FFMPEG_PID" "$AUDIO_PID"; do
    if [[ -n "$pid" ]]; then
      kill "$pid" 2>/dev/null || true
    fi
  done

  restore_terminal 2>/dev/null || true
  rm -rf "$TMPDIR_RUNTIME"
  rm -f "$PIDFILE"
}

stop() {
  local killed=0
  local pid

  if [[ -f "$PIDFILE" ]]; then
    while IFS= read -r pid; do
      [[ -n "$pid" ]] || continue
      if kill "$pid" 2>/dev/null; then
        killed=$((killed + 1))
      fi
    done <"$PIDFILE"
    rm -f "$PIDFILE"
  fi

  killed=$((killed + $(kill_matching 'mpv.*youtube\.com/watch')))
  killed=$((killed + $(kill_matching 'ffmpeg.*googlevideo')))
  killed=$((killed + $(kill_matching 'chafa --format symbols')))

  restore_terminal 2>/dev/null || true

  if [[ "$killed" -gt 0 ]]; then
    echo "Stopped claude-fm playback."
  else
    echo "No claude-fm sessions running."
  fi
}

resolve_media_url() {
  yt-dlp -g -f "$YTDLP_FORMAT" "$1" | tail -n 1
}

prepare_terminal() {
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l'
  printf '\033[?1049h\033[?25l\033[2J\033[H'
}

view_size() {
  local rows=$(( ${LINES:-24} - 1 ))
  if [[ "$rows" -lt 10 ]]; then
    rows=10
  fi
  printf '%sx%s\n' "${COLUMNS:-80}" "$rows"
}

render_frame() {
  local frame="$1"
  local mode="$2"
  local size
  size="$(view_size)"

  printf '\033[H\033[2J'
  if [[ "$mode" == "color" ]]; then
    chafa --format symbols --symbols all --colors 16 --align mid,mid --view-size "$size" --margin-bottom 0 "$frame"
  else
    chafa --format symbols --symbols ascii --colors none --align mid,mid --view-size "$size" --margin-bottom 0 "$frame"
  fi
}

wait_for_first_frame() {
  local frame="$1"
  local waited=0

  while [[ ! -s "$frame" && "$waited" -lt 30 ]]; do
    sleep 1
    waited=$((waited + 1))
  done

  [[ -s "$frame" ]]
}

render_loop() {
  local frame="$1"
  local mode="$2"
  local key=""

  while true; do
    if [[ -n "$FFMPEG_PID" ]] && ! kill -0 "$FFMPEG_PID" 2>/dev/null; then
      return 0
    fi
    if [[ -n "$AUDIO_PID" ]] && ! kill -0 "$AUDIO_PID" 2>/dev/null; then
      return 0
    fi

    if [[ -s "$frame" ]]; then
      render_frame "$frame" "$mode"
    fi

    if read -rsn1 -t 0.35 key; then
      case "$key" in
        q|$'\e')
          return 0
          ;;
      esac
    fi
  done
}

play_audio() {
  local url="$1"
  echo "▶ Claude FM - audio only - q quit"
  mpv --no-video "$url"
}

play_video() {
  local url="$1"
  local mode="$2"
  local stable="$3"
  local fps="2"
  local frame media_url

  if [[ "$stable" == "1" ]]; then
    fps="1"
  fi

  echo "▶ Claude FM - ${mode} - q quit"
  echo "  Resolving stream..."
  media_url="$(resolve_media_url "$url")"

  TMPDIR_RUNTIME="$(mktemp -d -t claude-fm.XXXXXX)"
  frame="$TMPDIR_RUNTIME/frame.jpg"

  : >"$PIDFILE"
  record_pid "$$"
  trap cleanup EXIT INT TERM HUP

  mpv --no-video --really-quiet "$url" &
  AUDIO_PID="$!"
  record_pid "$AUDIO_PID"

  ffmpeg -hide_banner -loglevel error -y -i "$media_url" -an -sn -vf "fps=${fps},scale=320:-1" -update 1 -q:v 5 "$frame" &
  FFMPEG_PID="$!"
  record_pid "$FFMPEG_PID"

  echo "  Loading ASCII frames..."
  if ! wait_for_first_frame "$frame"; then
    echo "claude-fm: could not load video frames. Try: claude-fm --audio" >&2
    return 1
  fi

  prepare_terminal
  render_loop "$frame" "$mode"
}

play() {
  local mode="ascii"
  local stable=0
  local url="${CLAUDE_FM_URL:-$DEFAULT_STREAM}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ascii)
        mode="ascii"
        shift
        ;;
      --color)
        mode="color"
        shift
        ;;
      --audio)
        mode="audio"
        shift
        ;;
      --stable)
        stable=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --version|-V)
        echo "claude-fm ${VERSION}"
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "claude-fm: unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
      *)
        url="$1"
        shift
        ;;
    esac
  done

  if ! doctor >/dev/null 2>&1; then
    doctor
    exit 1
  fi

  if [[ "$mode" == "audio" ]]; then
    play_audio "$url"
  else
    play_video "$url" "$mode" "$stable"
  fi
}

main() {
  case "${1:-}" in
    doctor)
      doctor
      ;;
    stop)
      stop
      ;;
    setup)
      setup_command
      ;;
    --help|-h|help)
      usage
      ;;
    --version|-V)
      echo "claude-fm ${VERSION}"
      ;;
    *)
      play "$@"
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
