#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.6"
DEFAULT_STREAM="https://www.youtube.com/watch?v=tRsQsTMvPNg"
# Low resolution keeps terminal rendering smooth on live HLS segments.
YTDLP_FORMAT='bestvideo[height<=360][fps<=30]+bestaudio/best[height<=360]'

usage() {
  cat <<'EOF'
claude-fm — play Claude FM (or any YouTube stream) in your terminal

Usage:
  claude-fm                 Play Claude FM in ASCII mode (default)
  claude-fm <url>           Play a YouTube livestream or video
  claude-fm --color         Color unicode block art
  claude-fm --ascii         ASCII mode (default)
  claude-fm --audio         Audio only (no video)
  claude-fm --stable        Extra-stable video (lower res, fewer artifacts)
  claude-fm doctor          Check playback dependencies
  claude-fm stop            Kill any claude-fm / mpv sessions
  claude-fm setup           Print recommended dependency install command
  claude-fm --help          Show this help
  claude-fm --version       Show version

Controls (mpv):
  q          quit
  space      pause / resume
  m          mute
  9 / 0      volume down / up
  f          toggle fullscreen (windowed terminals)

Install:
  curl -fsSL https://raw.githubusercontent.com/cyberpapiii/claude-fm-terminal/main/install.sh | sh
EOF
}

have() {
  command -v "$1" >/dev/null 2>&1
}

setup_command() {
  case "$(uname -s)" in
    Darwin)
      if have brew; then
        echo "brew install yt-dlp mpv"
      else
        echo "# Install Homebrew first: https://brew.sh"
        echo "brew install yt-dlp mpv"
      fi
      ;;
    Linux)
      if have apt-get; then
        echo "sudo apt-get update && sudo apt-get install -y yt-dlp mpv"
      elif have dnf; then
        echo "sudo dnf install -y yt-dlp mpv"
      elif have pacman; then
        echo "sudo pacman -S --needed yt-dlp mpv"
      else
        echo "# Install yt-dlp and mpv with your package manager"
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      if have winget; then
        echo "winget install yt-dlp.yt-dlp mpv.net"
      else
        echo "# Install yt-dlp and mpv manually on Windows"
      fi
      ;;
    *)
      echo "# Install yt-dlp and mpv for your platform"
      ;;
  esac
}

stop() {
  local killed=0
  local pid

  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    kill "$pid" 2>/dev/null && killed=$((killed + 1)) || true
  done < <(pgrep -f 'claude-fm|mpv.*youtube|mpv.*tRsQsTMvPNg' 2>/dev/null || true)

  sleep 0.5

  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    kill -9 "$pid" 2>/dev/null && killed=$((killed + 1)) || true
  done < <(pgrep -f 'claude-fm|mpv.*youtube|mpv.*tRsQsTMvPNg' 2>/dev/null || true)

  restore_terminal 2>/dev/null || true

  if [[ "$killed" -gt 0 ]]; then
    echo "Stopped claude-fm playback."
  else
    echo "No claude-fm sessions running."
  fi
}

doctor() {
  local ok=1
  echo "claude-fm doctor"
  echo

  if have yt-dlp; then
    echo "  yt-dlp  ok  ($(command -v yt-dlp))"
  else
    echo "  yt-dlp  missing"
    ok=0
  fi

  if have mpv; then
    echo "  mpv     ok  ($(command -v mpv))"
  else
    echo "  mpv     missing"
    ok=0
  fi

  echo
  if [[ "$ok" -eq 1 ]]; then
    echo "Ready. Run: claude-fm"
    return 0
  fi

  echo "Install dependencies:"
  setup_command
  return 1
}

pick_vo() {
  echo "tct"
}

tct_geometry() {
  # Trailing newline required: bash 3.2 read returns 1 without it, and set -e aborts.
  # Reserve one line for the terminal chrome (tab bar / status line).
  local rows=$(( ${LINES:-24} - 1 ))
  if [[ "$rows" -lt 10 ]]; then
    rows=10
  fi
  printf '%s %s\n' "${COLUMNS:-80}" "$rows"
}

mpv_extra_args() {
  local mode="$1"
  local stable="$2"
  local -a args=()
  local width height
  read -r width height < <(tct_geometry)

  if [[ "$stable" == "1" && "$mode" != "audio" ]]; then
    args+=(--ytdl-format='worstvideo[height<=240]+worstaudio/worst')
    args+=(--framedrop=vo)
  else
    args+=(--ytdl-format="$YTDLP_FORMAT")
    if [[ "$mode" != "audio" ]]; then
      args+=(--profile=sw-fast)
    fi
  fi

  args+=(--force-window=no)
  # Default bindings enable terminal mouse tracking, which leaks ^[[MC... garbage with tct.
  args+=(--input-default-bindings=no)
  args+=(--input-bindings='q quit')
  args+=(--input-bindings='ESC quit')
  args+=(--input-bindings='SPACE cycle pause')
  args+=(--input-bindings='m cycle mute')
  args+=(--input-bindings='9 add volume -2')
  args+=(--input-bindings='0 add volume 2')
  args+=(--input-vo-keyboard=no)
  args+=(--input-cursor=no)

  # tct output breaks when mpv prints status/logs over the frame.
  args+=(--really-quiet)
  args+=(--no-terminal)
  args+=(--terminal=no)
  args+=(--osd-level=0)
  args+=(--msg-level=all=no)
  args+=(--idle=no)

  # Live HLS: avoid cache pauses that desync terminal frames.
  if [[ "$mode" != "audio" ]]; then
    args+=(--cache=no)
    args+=(--demuxer-readahead-secs=0)
  fi

  case "$mode" in
    ascii)
      args+=(--vo-tct-algo=plain)
      args+=(--vo-tct-buffering=frame)
      args+=(--vo-tct-width="$width")
      args+=(--vo-tct-height="$height")
      ;;
    color)
      args+=(--vo-tct-algo=half-blocks)
      args+=(--vo-tct-buffering=frame)
      args+=(--vo-tct-width="$width")
      args+=(--vo-tct-height="$height")
      ;;
    audio)
      args+=(--no-video)
      ;;
  esac

  printf '%s\0' "${args[@]}"
}

prepare_terminal() {
  # Disable mouse reporting before alternate screen (prevents ^[[MC... leak below video).
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l'
  # Alternate screen: video + noise stay off your shell scrollback.
  printf '\033[?1049h\033[?25l\033[2J\033[H'
}

restore_terminal() {
  # Turn off mouse reporting modes terminals/mpv may leave enabled.
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l'
  printf '\033[?25h\033[0m'
  printf '\033[?1049l'
  stty sane 2>/dev/null || true
}

print_banner() {
  local mode="$1"
  local label="ascii"

  case "$mode" in
    color) label="color" ;;
    audio) label="audio only" ;;
  esac

  echo "▶ Claude FM  ·  ${label}  ·  q quit  m mute  space pause  9/0 volume" >&2
}

play() {
  local mode="ascii"
  local stable=0
  local url="${CLAUDE_FM_URL:-$DEFAULT_STREAM}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ascii)
        mode="ascii"
        shift
        ;;
      --color)
        mode="color"
        shift
        ;;
      --audio)
        mode="audio"
        shift
        ;;
      --stable)
        stable=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --version|-V)
        echo "claude-fm ${VERSION}"
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "claude-fm: unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
      *)
        url="$1"
        shift
        ;;
    esac
  done

  if [[ $# -gt 0 ]]; then
    url="$1"
  fi

  if ! doctor >/dev/null 2>&1; then
    doctor
    exit 1
  fi

  local vo
  vo="$(pick_vo)"

  local -a mpv_args=()
  while IFS= read -r -d '' arg; do
    mpv_args+=("$arg")
  done < <(mpv_extra_args "$mode" "$stable")

  if [[ "$mode" == "audio" ]]; then
    print_banner "$mode"
    mpv ${mpv_args+"${mpv_args[@]}"} "$url"
    return $?
  fi

  print_banner "$mode"
  echo "  Loading stream (may take 10–20s)..." >&2

  prepare_terminal
  trap restore_terminal EXIT INT TERM HUP

  mpv --vo="$vo" ${mpv_args+"${mpv_args[@]}"} "$url"
  local status=$?
  restore_terminal
  trap - EXIT INT TERM HUP

  if [[ "$status" -ne 0 ]]; then
    echo "claude-fm: playback failed (exit $status). Try: claude-fm doctor" >&2
  fi

  return "$status"
}

main() {
  if [[ $# -eq 0 ]]; then
    play
    return
  fi

  case "$1" in
    play)
      shift
      play "$@"
      ;;
    doctor)
      doctor
      ;;
    stop)
      stop
      ;;
    setup)
      setup_command
      ;;
    --help|-h|help)
      usage
      ;;
    --version|-V)
      echo "claude-fm ${VERSION}"
      ;;
    *)
      play "$@"
      ;;
  esac
}

main "$@"
