#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.7"
DEFAULT_STREAM="https://www.youtube.com/watch?v=tRsQsTMvPNg"
YTDLP_FORMAT='bestvideo[height<=360][fps<=30]+bestaudio/best[height<=360]'
CLAUDE_FM_PIDFILE="${CLAUDE_FM_PIDFILE:-${TMPDIR:-/tmp}/claude-fm-${UID:-0}.pid}"

usage() {
  cat <<'EOF'
claude-fm — play Claude FM (or any YouTube stream) in your terminal

Usage:
  claude-fm                 Play Claude FM in ASCII mode (default)
  claude-fm <url>           Play a YouTube livestream or video
  claude-fm --color         Color unicode block art
  claude-fm --audio         Audio only (no video)
  claude-fm --stable        Extra-stable video (lower res, fewer artifacts)
  claude-fm stop            Kill stuck claude-fm / mpv sessions
  claude-fm doctor          Check playback dependencies
  claude-fm setup           Print recommended dependency install command
  claude-fm --help          Show this help
  claude-fm --version       Show version

Controls:
  q          quit
  space      pause / resume
  m          mute
  9 / 0      volume down / up

Install:
  curl -fsSL https://raw.githubusercontent.com/cyberpapiii/claude-fm-terminal/main/install.sh | sh
EOF
}

have() {
  command -v "$1" >/dev/null 2>&1
}

setup_command() {
  case "$(uname -s)" in
    Darwin)
      if have brew; then
        echo "brew install yt-dlp mpv"
      else
        echo "# Install Homebrew first: https://brew.sh"
        echo "brew install yt-dlp mpv"
      fi
      ;;
    Linux)
      if have apt-get; then
        echo "sudo apt-get update && sudo apt-get install -y yt-dlp mpv"
      elif have dnf; then
        echo "sudo dnf install -y yt-dlp mpv"
      elif have pacman; then
        echo "sudo pacman -S --needed yt-dlp mpv"
      else
        echo "# Install yt-dlp and mpv with your package manager"
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*)
      if have winget; then
        echo "winget install yt-dlp.yt-dlp mpv.net"
      else
        echo "# Install yt-dlp and mpv manually on Windows"
      fi
      ;;
    *)
      echo "# Install yt-dlp and mpv for your platform"
      ;;
  esac
}

tct_geometry() {
  local rows=$(( ${LINES:-24} - 1 ))
  if [[ "$rows" -lt 10 ]]; then
    rows=10
  fi
  printf '%s %s\n' "${COLUMNS:-80}" "$rows"
}

build_mpv_args() {
  local mode="$1"
  local stable="$2"
  local width height

  MPV_ARGS=()
  read -r width height < <(tct_geometry)

  if [[ "$stable" == "1" && "$mode" != "audio" ]]; then
    MPV_ARGS+=(--ytdl-format='worstvideo[height<=240]+worstaudio/worst')
    MPV_ARGS+=(--framedrop=vo)
  else
    MPV_ARGS+=(--ytdl-format="$YTDLP_FORMAT")
    if [[ "$mode" != "audio" ]]; then
      MPV_ARGS+=(--profile=sw-fast)
    fi
  fi

  MPV_ARGS+=(--force-window=no)
  MPV_ARGS+=(--input-default-bindings=no)
  MPV_ARGS+=(--input-bindings='q quit')
  MPV_ARGS+=(--input-bindings='ESC quit')
  MPV_ARGS+=(--input-bindings='SPACE cycle pause')
  MPV_ARGS+=(--input-bindings='m cycle mute')
  MPV_ARGS+=(--input-bindings='9 add volume -2')
  MPV_ARGS+=(--input-bindings='0 add volume 2')
  MPV_ARGS+=(--input-vo-keyboard=no)
  MPV_ARGS+=(--input-cursor=no)
  MPV_ARGS+=(--really-quiet)
  MPV_ARGS+=(--no-terminal)
  MPV_ARGS+=(--terminal=no)
  MPV_ARGS+=(--osd-level=0)
  MPV_ARGS+=(--msg-level=all=no)
  MPV_ARGS+=(--idle=no)

  if [[ "$mode" != "audio" ]]; then
    MPV_ARGS+=(--cache=no)
    MPV_ARGS+=(--demuxer-readahead-secs=0)
  fi

  case "$mode" in
    ascii)
      MPV_ARGS+=(--vo-tct-algo=plain)
      ;;
    color)
      MPV_ARGS+=(--vo-tct-algo=half-blocks)
      ;;
    audio)
      MPV_ARGS+=(--no-video)
      ;;
  esac

  if [[ "$mode" != "audio" ]]; then
    MPV_ARGS+=(--vo-tct-buffering=frame)
    MPV_ARGS+=(--vo-tct-width="$width")
    MPV_ARGS+=(--vo-tct-height="$height")
  fi
}

prepare_terminal() {
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l'
  printf '\033[?1049h\033[?25l\033[2J\033[H'
}

restore_terminal() {
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?1015l'
  printf '\033[?25h\033[0m'
  printf '\033[?1049l'
  stty sane 2>/dev/null || true
}

clear_pidfile() {
  rm -f "$CLAUDE_FM_PIDFILE"
}

record_pidfile() {
  echo "$$" >"$CLAUDE_FM_PIDFILE"
}

stop() {
  local killed=0
  local pid

  if [[ -f "$CLAUDE_FM_PIDFILE" ]]; then
    while IFS= read -r pid; do
      [[ -n "$pid" ]] || continue
      if kill "$pid" 2>/dev/null; then
        killed=$((killed + 1))
      fi
    done <"$CLAUDE_FM_PIDFILE"
    rm -f "$CLAUDE_FM_PIDFILE"
  fi

  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    if kill "$pid" 2>/dev/null; then
      killed=$((killed + 1))
    fi
  done < <(pgrep -f 'mpv --vo=tct.*youtube\.com/watch' 2>/dev/null || true)

  sleep 0.5

  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    if kill -9 "$pid" 2>/dev/null; then
      killed=$((killed + 1))
    fi
  done < <(pgrep -f 'mpv --vo=tct.*youtube\.com/watch' 2>/dev/null || true)

  restore_terminal 2>/dev/null || true

  if [[ "$killed" -gt 0 ]]; then
    echo "Stopped claude-fm playback."
  else
    echo "No claude-fm sessions running."
  fi
}

doctor() {
  local ok=1
  echo "claude-fm doctor"
  echo

  if have yt-dlp; then
    echo "  yt-dlp  ok  ($(command -v yt-dlp))"
  else
    echo "  yt-dlp  missing"
    ok=0
  fi

  if have mpv; then
    echo "  mpv     ok  ($(command -v mpv))"
  else
    echo "  mpv     missing"
    ok=0
  fi

  echo
  if [[ "$ok" -eq 1 ]]; then
    echo "Ready. Run: claude-fm"
    return 0
  fi

  echo "Install dependencies:"
  setup_command
  return 1
}

print_banner() {
  local mode="$1"
  local label="ascii"

  case "$mode" in
    color) label="color" ;;
    audio) label="audio only" ;;
  esac

  echo "▶ Claude FM  ·  ${label}  ·  q quit  m mute  space pause  9/0 volume" >&2
}

play() {
  local mode="ascii"
  local stable=0
  local url="${CLAUDE_FM_URL:-$DEFAULT_STREAM}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ascii)
        mode="ascii"
        shift
        ;;
      --color)
        mode="color"
        shift
        ;;
      --audio)
        mode="audio"
        shift
        ;;
      --stable)
        stable=1
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --version|-V)
        echo "claude-fm ${VERSION}"
        exit 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "claude-fm: unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
      *)
        url="$1"
        shift
        ;;
    esac
  done

  if [[ $# -gt 0 ]]; then
    url="$1"
  fi

  if ! doctor >/dev/null 2>&1; then
    doctor
    exit 1
  fi

  build_mpv_args "$mode" "$stable"
  print_banner "$mode"

  if [[ "$mode" == "audio" ]]; then
    record_pidfile
    trap clear_pidfile EXIT INT TERM HUP
    mpv ${MPV_ARGS+"${MPV_ARGS[@]}"} "$url"
    return $?
  fi

  echo "  Loading stream (may take 10–20s)..." >&2
  record_pidfile
  prepare_terminal
  trap 'restore_terminal; clear_pidfile' EXIT INT TERM HUP

  mpv --vo=tct ${MPV_ARGS+"${MPV_ARGS[@]}"} "$url"
  local status=$?
  restore_terminal
  clear_pidfile
  trap - EXIT INT TERM HUP

  if [[ "$status" -ne 0 ]]; then
    echo "claude-fm: playback failed (exit $status). Try: claude-fm doctor" >&2
  fi

  return "$status"
}

main() {
  if [[ $# -eq 0 ]]; then
    play
    return
  fi

  case "$1" in
    doctor)
      doctor
      ;;
    stop)
      stop
      ;;
    setup)
      setup_command
      ;;
    --help|-h|help)
      usage
      ;;
    --version|-V)
      echo "claude-fm ${VERSION}"
      ;;
    *)
      play "$@"
      ;;
  esac
}

main "$@"
